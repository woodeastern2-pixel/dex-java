<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.WhereIsIt" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/navy_accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/orange_accent</item>
        <item name="colorTertiary">@color/amber_accent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/bg_canvas</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowBackground">@color/bg_canvas</item>
        <item name="materialButtonStyle">@style/Widget.WhereIsIt.Button</item>
        <item name="textInputStyle">@style/Widget.WhereIsIt.TextInputLayout</item>
        <item name="shapeAppearanceSmallComponent">@style/Shape.WhereIsIt.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/Shape.WhereIsIt.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/Shape.WhereIsIt.Large</item>
    </style>

    <style name="Widget.WhereIsIt.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">18dp</item>
        <item name="android:minHeight">54dp</item>
        <item name="backgroundTint">@color/navy_accent</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.WhereIsIt.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface_soft</item>
        <item name="boxStrokeColor">@color/stroke_soft</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="shapeAppearance">@style/Shape.WhereIsIt.Small</item>
        <item name="hintTextColor">@color/beige_gray</item>
    </style>

    <style name="Shape.WhereIsIt.Small" parent="ShapeAppearance.Material3.Corner.Small">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="Shape.WhereIsIt.Medium" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerSize">24dp</item>
    </style>

    <style name="Shape.WhereIsIt.Large" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerSize">30dp</item>
    </style>
</resources>
