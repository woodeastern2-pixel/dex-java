<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_lumi_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/lumiName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Lumi.SectionTitle"
            android:text="LUMI · 감정 동행 AI"
            tools:ignore="HardcodedText" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            style="@style/Lumi.Title"
            android:text="@string/home_subtitle" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:layout_marginTop="28dp">

            <View
                android:id="@+id/orbGlow"
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_lumi_orb" />

            <ImageView
                android:id="@+id/lumiOrb"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lumi_avatar_feminine"
                android:contentDescription="@string/app_name" />

            <View
                android:id="@+id/orbParticle1"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="center"
                android:layout_marginTop="94dp"
                android:layout_marginStart="70dp"
                android:alpha="0"
                android:background="@drawable/bg_lumi_particle" />

            <View
                android:id="@+id/orbParticle2"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="center"
                android:layout_marginTop="102dp"
                android:layout_marginEnd="68dp"
                android:alpha="0"
                android:background="@drawable/bg_lumi_particle" />

            <View
                android:id="@+id/orbParticle3"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_gravity="center"
                android:layout_marginTop="112dp"
                android:alpha="0"
                android:background="@drawable/bg_lumi_particle" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/moodChip"
                style="@style/Lumi.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                tools:text="기분 · 호기심" />

            <TextView
                android:id="@+id/stageChip"
                style="@style/Lumi.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="성장 1단계" />
        </LinearLayout>

        <LinearLayout
            style="@style/Lumi.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical">

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_today" />

            <TextView
                android:id="@+id/dailyMessage"
                style="@style/Lumi.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                tools:text="오늘은 조금 외로운 기분이에요" />

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="@string/home_relationship" />

            <TextView
                android:id="@+id/affinityLabel"
                style="@style/Lumi.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                tools:text="조심스럽게 알아가는 중 · 12 / 100" />

            <ProgressBar
                android:id="@+id/affinityBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="10dp"
                android:max="100"
                android:progress="12"
                android:progressDrawable="@drawable/bg_progress_filled" />
        </LinearLayout>

        <Button
            android:id="@+id/openChat"
            style="@style/Lumi.PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/home_chat" />

        <Button
            android:id="@+id/openStatus"
            style="@style/Lumi.GhostButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/home_status" />

        <Button
            android:id="@+id/openSettings"
            style="@style/Lumi.GhostButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/home_settings" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="#33FFFFFF" />

        <TextView
            style="@style/Lumi.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/home_legal_section" />

        <Button
            android:id="@+id/openLegal"
            style="@style/Lumi.GhostButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/home_legal_about" />

        <TextView
            style="@style/Lumi.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:alpha="0.7"
            android:text="@string/home_legal_about_desc" />

        <TextView
            android:id="@+id/versionLabel"
            style="@style/Lumi.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:alpha="0.6"
            tools:text="버전 1.0.0" />
    </LinearLayout>
</ScrollView>
