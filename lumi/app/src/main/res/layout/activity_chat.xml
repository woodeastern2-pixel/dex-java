<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/chatRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_lumi_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="14dp">

        <TextView
            style="@style/Lumi.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LUMI · 대화"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/chatMoodLine"
            style="@style/Lumi.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            tools:text="지금 루미는 호기심 가득해요" />

            <View
                android:id="@+id/chatMoodAura"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_lumi_orb"
                android:alpha="0.28" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp" />

    <TextView
        android:id="@+id/typingIndicator"
        style="@style/Lumi.Muted"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="22dp"
        android:layout_marginBottom="6dp"
        android:text="@string/chat_typing"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#0F0B2E">

        <ImageButton
            android:id="@+id/attachImageButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_lumi_button_ghost"
            android:src="@android:drawable/ic_menu_gallery"
            android:contentDescription="@string/chat_attach_image" />

        <ImageButton
            android:id="@+id/voiceButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_lumi_button_ghost"
            android:src="@android:drawable/ic_btn_speak_now"
            android:contentDescription="@string/chat_attach_voice" />

        <EditText
            android:id="@+id/inputField"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input"
            android:hint="@string/chat_hint"
            android:textColorHint="@color/lumi_text_muted"
            android:textColor="@color/lumi_text_primary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:inputType="text"
            android:maxLines="3"
            android:imeOptions="actionSend"
            android:autofillHints="off"
            android:importantForAutofill="no" />

        <ImageButton
            android:id="@+id/sendButton"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_lumi_button_primary"
            android:src="@drawable/ic_send"
            android:contentDescription="@string/chat_send" />
    </LinearLayout>
</LinearLayout>
