<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_lumi_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            style="@style/Lumi.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/consent_title" />

        <TextView
            style="@style/Lumi.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/consent_intro" />

        <TextView
            style="@style/Lumi.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/consent_required_header" />

        <CheckBox
            android:id="@+id/cbTerms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#FFFFFF"
            android:text="@string/consent_terms" />

        <CheckBox
            android:id="@+id/cbAge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:text="@string/consent_age" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/btnViewTerms"
                style="@style/Lumi.GhostButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/consent_view_terms" />

            <Button
                android:id="@+id/btnViewPrivacy"
                style="@style/Lumi.GhostButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/consent_view_privacy" />
        </LinearLayout>

        <TextView
            style="@style/Lumi.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/consent_optional_header" />

        <CheckBox
            android:id="@+id/cbOverseas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#FFFFFF"
            android:text="@string/consent_overseas" />

        <CheckBox
            android:id="@+id/cbVoice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:text="@string/consent_voice" />

        <Button
            android:id="@+id/btnContinue"
            style="@style/Lumi.PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/consent_continue" />

        <Button
            android:id="@+id/btnDecline"
            style="@style/Lumi.GhostButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/consent_decline" />
    </LinearLayout>
</ScrollView>
