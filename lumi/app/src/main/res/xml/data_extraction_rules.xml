<?xml version="1.0" encoding="utf-8"?>
<!--
    민감 데이터(API 키, 대화 기록, 음성 전사 텍스트, 기억)를 클라우드 백업이나
    기기 간 전송에 포함하지 않는다.
    Android 12+ 의 D2D / Cloud 백업 모두에서 제외.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="lumi_settings_secure.xml" />
        <exclude domain="sharedpref" path="lumi_settings.xml" />
        <exclude domain="database" path="lumi.db" />
        <exclude domain="database" path="lumi.db-journal" />
        <exclude domain="database" path="lumi.db-shm" />
        <exclude domain="database" path="lumi.db-wal" />
        <exclude domain="file" path="voice/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="lumi_settings_secure.xml" />
        <exclude domain="sharedpref" path="lumi_settings.xml" />
        <exclude domain="database" path="lumi.db" />
        <exclude domain="database" path="lumi.db-journal" />
        <exclude domain="database" path="lumi.db-shm" />
        <exclude domain="database" path="lumi.db-wal" />
        <exclude domain="file" path="voice/" />
    </device-transfer>
</data-extraction-rules>
