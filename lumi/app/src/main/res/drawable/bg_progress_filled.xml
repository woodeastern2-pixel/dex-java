<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="999dp" />
            <solid android:color="#3A3175" />
        </shape>
    </item>
    <item>
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="999dp" />
                <gradient
                    android:angle="0"
                    android:startColor="#5DE2FF"
                    android:endColor="#9C7BFF"
                    android:type="linear" />
            </shape>
        </clip>
    </item>
</layer-list>
