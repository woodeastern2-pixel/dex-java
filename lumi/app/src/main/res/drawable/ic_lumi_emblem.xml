                android:startX="20" android:startY="20"
                android:endX="100" android:endY="100"
                android:type="linear">
                <item android:offset="0" android:color="#FFE4F1" />
                <item android:offset="0.55" android:color="#D9C9FF" />
                <item android:offset="1" android:color="#A6C7FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Soft halo behind the character -->
    <path
        android:pathData="M54,62 m-34,0 a34,34 0 1,0 68,0 a34,34 0 1,0 -68,0"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.32" />

    <!-- Lumi body: rounded blob in soft cream/white -->
