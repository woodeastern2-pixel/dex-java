        android:pathData="M43,58 q3,3 6,0"
        android:strokeColor="#5A4AA8"
        android:strokeWidth="2.6"
        android:strokeLineCap="round" />

    <!-- Smiling closed eyes (right) -->
    <path
        android:pathData="M59,58 q3,3 6,0"
