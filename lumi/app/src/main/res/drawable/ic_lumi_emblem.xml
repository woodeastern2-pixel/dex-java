        android:strokeWidth="2.6"
        android:strokeLineCap="round" />

    <!-- Tiny smile -->
    <path
        android:pathData="M50,68 q4,3 8,0"
        android:strokeColor="#7A5BD6"
        android:strokeWidth="2.2"
        android:strokeLineCap="round" />

    <!-- Pink cheek (left) -->
    <path
        android:pathData="M40,66 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0"
        android:fillColor="#FF9FC4"
