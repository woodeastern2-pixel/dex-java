<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_paper"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="성 한자"
        android:textColor="@color/deep_navy"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp">

        <TextView
            android:id="@+id/textSurnameSelected"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="아직 선택되지 않았습니다"
            android:textColor="@color/charcoal" />

        <Button
            android:id="@+id/btnSelectSurname"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_button_primary"
            android:text="선택"
            android:textColor="@color/white"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="이름 첫 번째 한자"
        android:textColor="@color/deep_navy"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp">

        <TextView
            android:id="@+id/textFirstSelected"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="아직 선택되지 않았습니다"
            android:textColor="@color/charcoal" />

        <Button
            android:id="@+id/btnSelectFirst"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_button_primary"
            android:text="선택"
            android:textColor="@color/white"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="이름 두 번째 한자"
        android:textColor="@color/deep_navy"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp">

        <TextView
            android:id="@+id/textSecondSelected"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="아직 선택되지 않았습니다"
            android:textColor="@color/charcoal" />

        <Button
            android:id="@+id/btnSelectSecond"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_button_primary"
            android:text="선택"
            android:textColor="@color/white"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/textHelper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="여러 후보 중 원하는 한자를 선택해 주세요"
        android:textColor="@color/charcoal"
        android:textSize="13sp" />

    <Button
        android:id="@+id/btnDone"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_primary"
        android:text="이름 선택 완료"
        android:textColor="@color/white" />

</LinearLayout>
