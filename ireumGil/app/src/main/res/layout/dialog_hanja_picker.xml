<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_paper"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="공식 인명용 한자 데이터 기준"
        android:textColor="@color/deep_navy"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="출처: 대법원 인명용 한자표 / 국가법령정보센터 별표 / 교육부 한문교육용 기초한자"
        android:textColor="@color/charcoal"
        android:textSize="12sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="일부 획수/오행 정보는 성명학 기준 보완 데이터입니다"
        android:textColor="@color/soft_red"
        android:textSize="12sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="한글 음으로 찾기"
        android:textColor="@color/deep_navy"
        android:textSize="16sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/editReading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_card"
        android:hint="예: 김, 이, 박, 최"
        android:padding="10dp" />

    <EditText
        android:id="@+id/editCharacter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_card"
        android:hint="한자 글자 검색 (예: 民)"
        android:padding="10dp" />

    <EditText
        android:id="@+id/editMeaning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_card"
        android:hint="뜻 키워드 검색 (예: 지혜)"
        android:padding="10dp" />

    <EditText
        android:id="@+id/editStroke"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_card"
        android:hint="획수 필터 (숫자)"
        android:inputType="number"
        android:padding="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <CheckBox
            android:id="@+id/checkAllowedOnly"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:checked="true"
            android:text="인명용만"
            android:textColor="@color/charcoal" />

        <CheckBox
            android:id="@+id/checkSurnameOnly"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="성씨용만"
            android:textColor="@color/charcoal" />
    </LinearLayout>

    <TextView
        android:id="@+id/textSelected"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_chip"
        android:paddingLeft="10dp"
        android:paddingTop="5dp"
        android:paddingRight="10dp"
        android:paddingBottom="5dp"
        android:text="선택한 한자: 없음"
        android:textColor="@color/soft_red"
        android:textSize="13sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="손글씨로 찾기"
        android:textColor="@color/deep_navy"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="한자를 그려주세요"
        android:textColor="@color/charcoal"
        android:textSize="13sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_card">

        <com.ireumgil.ui.HandwritingCanvasView
            android:id="@+id/handwritingCanvas"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnClearCanvas"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card"
            android:text="지우기"
            android:textColor="@color/charcoal" />

        <Button
            android:id="@+id/btnFindCandidates"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_primary"
            android:text="후보 찾기"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/btnConfirmSelection"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_primary"
            android:text="선택하기"
            android:textColor="@color/white" />
    </LinearLayout>

    <TextView
        android:id="@+id/textHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:lineSpacingExtra="2dp"
        android:text="손글씨 인식은 현재 기본 후보 추천 방식으로 제공됩니다."
        android:textColor="@color/soft_red"
        android:textSize="13sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="검색 결과"
        android:textColor="@color/deep_navy"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textResultCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="검색 결과 0개"
        android:textColor="@color/charcoal"
        android:textSize="13sp" />

    <ListView
        android:id="@+id/listCandidates"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_marginTop="8dp"
        android:divider="#00000000"
        android:dividerHeight="8dp" />
</LinearLayout>
