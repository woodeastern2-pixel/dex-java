<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_paper"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="한글 음으로 한자 찾기"
        android:textColor="@color/deep_navy"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/editReading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_card"
        android:hint="예: 민, 서, 준"
        android:padding="10dp" />

    <Button
        android:id="@+id/btnSearch"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_card"
        android:text="후보 검색"
        android:textColor="@color/charcoal" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="손글씨 입력(준비 중)"
        android:textColor="@color/deep_navy"
        android:textStyle="bold" />

    <FrameLayout
        android:id="@+id/handwritingArea"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_card">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:text="여기에 한자를 손글씨로 입력하는 UI 자리입니다.\nMVP에서는 인식 기능 대신 수동 후보 선택을 제공합니다."
            android:textColor="@color/charcoal"
            android:textSize="13sp" />
    </FrameLayout>

    <Button
        android:id="@+id/btnHandwritingFallback"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_card"
        android:text="손글씨 대신 후보 목록 보기"
        android:textColor="@color/charcoal" />

    <TextView
        android:id="@+id/textHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="검색 결과에서 한자를 선택하세요."
        android:textColor="@color/soft_red"
        android:textSize="13sp" />

    <ListView
        android:id="@+id/listCandidates"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="8dp"
        android:divider="#11000000"
        android:dividerHeight="1dp" />

</LinearLayout>
