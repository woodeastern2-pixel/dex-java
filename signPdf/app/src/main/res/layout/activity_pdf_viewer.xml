<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPageBackground">

    <!-- 상단 툴바 -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorToolbar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 저장 / 공유 버튼을 Toolbar 오른쪽에 배치 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:orientation="horizontal"
            android:paddingEnd="8dp">

            <ProgressBar
                android:id="@+id/progress_saving"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="8dp"
                android:visibility="gone"/>

            <ImageButton
                android:id="@+id/btn_save"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_save"
                android:contentDescription="@string/save"
                android:tint="@color/colorTextOnPrimary"/>

            <ImageButton
                android:id="@+id/btn_share"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_share"
                android:contentDescription="@string/share"
                android:tint="@color/colorTextOnPrimary"/>

        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- PDF 뷰 + 어노테이션 레이어 -->
    <FrameLayout
        android:id="@+id/pdf_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/bottom_panel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.signpdf.app.viewer.PdfRenderView
            android:id="@+id/pdf_render_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <com.signpdf.app.viewer.AnnotationLayerView
            android:id="@+id/annotation_layer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </FrameLayout>

    <!-- 페이지 이동 오버레이 -->
    <LinearLayout
        android:id="@+id/page_nav_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#CC000000"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toTopOf="@id/bottom_panel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp">

        <ImageButton
            android:id="@+id/btn_prev_page"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_chevron_left"
            android:tint="#FFFFFF"/>

        <TextView
            android:id="@+id/tv_page_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 / 1"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:paddingHorizontal="8dp"/>

        <ImageButton
            android:id="@+id/btn_next_page"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_chevron_right"
            android:tint="#FFFFFF"/>

    </LinearLayout>

    <!-- 하단 도구 패널 -->
    <LinearLayout
        android:id="@+id/bottom_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorBottomPanel"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:id="@+id/bottom_panel_handle"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:background="@color/colorBottomPanel"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/toggle_bottom_panel">

            <View
                android:id="@+id/bottom_panel_grip"
                android:layout_width="44dp"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:background="@drawable/bottom_panel_grip_bg" />

        </FrameLayout>

        <!-- 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorBottomPanelBorder"/>

        <!-- 저장 / 공유 액션: 작은 화면에서도 명확하게 보이도록 텍스트 버튼 제공 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_bottom"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="PDF 저장"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextOnPrimary"
                app:backgroundTint="@color/colorPrimary"
                app:cornerRadius="10dp"
                app:icon="@drawable/ic_save"
                app:iconTint="@color/colorTextOnPrimary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_share_bottom"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="공유"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                app:backgroundTint="@color/colorSurface"
                app:cornerRadius="10dp"
                app:icon="@drawable/ic_share"
                app:iconTint="@color/colorPrimary"
                app:strokeColor="@color/colorPrimary"
                app:strokeWidth="1dp" />

        </LinearLayout>

        <!-- 도구 버튼 행 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp">

            <ImageButton
                android:id="@+id/btn_pen"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/tool_button_bg"
                android:src="@drawable/ic_pen"
                android:tint="@color/colorTextPrimary"
                android:contentDescription="@string/pen"/>

            <ImageButton
                android:id="@+id/btn_pencil"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/tool_button_bg"
                android:src="@drawable/ic_pencil"
                android:tint="@color/colorTextPrimary"
                android:contentDescription="@string/pencil"/>

            <ImageButton
                android:id="@+id/btn_highlighter"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/tool_button_bg"
                android:src="@drawable/ic_highlighter"
                android:tint="@color/colorTextPrimary"
                android:contentDescription="@string/highlighter"/>

            <ImageButton
                android:id="@+id/btn_eraser"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/tool_button_bg"
                android:src="@drawable/ic_eraser"
                android:tint="@color/colorTextPrimary"
                android:contentDescription="@string/eraser"/>

            <ImageButton
                android:id="@+id/btn_pan"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/tool_button_bg"
                android:src="@drawable/ic_pan"
                android:tint="@color/colorTextPrimary"
                android:contentDescription="@string/pan"/>

            <ImageButton
                android:id="@+id/btn_select_area"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/tool_button_bg"
                android:src="@drawable/ic_select_area"
                android:tint="@color/colorTextPrimary"
                android:contentDescription="@string/select_area"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <ImageButton
                android:id="@+id/btn_undo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_undo"
                android:tint="@color/colorTextPrimary"
                android:contentDescription="@string/undo"/>

            <ImageButton
                android:id="@+id/btn_redo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_redo"
                android:tint="@color/colorTextPrimary"
                android:contentDescription="@string/redo"/>

        </LinearLayout>

        <!-- 색상 행 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">

            <!-- 색상 버튼들 -->
            <ImageButton
                android:id="@+id/color_btn_0"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@android:color/black"
                android:src="@null"
                android:layout_marginEnd="6dp"/>

            <ImageButton
                android:id="@+id/color_btn_1"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="#1565C0"
                android:src="@null"
                android:layout_marginEnd="6dp"/>

            <ImageButton
                android:id="@+id/color_btn_2"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="#C62828"
                android:src="@null"
                android:layout_marginEnd="6dp"/>

            <ImageButton
                android:id="@+id/color_btn_3"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="#2E7D32"
                android:src="@null"
                android:layout_marginEnd="6dp"/>

            <ImageButton
                android:id="@+id/color_btn_4"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="#757575"
                android:src="@null"
                android:layout_marginEnd="6dp"/>

            <ImageButton
                android:id="@+id/color_btn_5"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@android:color/white"
                android:src="@null"
                android:layout_marginEnd="6dp"/>

            <ImageButton
                android:id="@+id/color_btn_6"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="#F9A825"
                android:src="@null"
                android:layout_marginEnd="12dp"/>

        </LinearLayout>

        <!-- 펜촉 크기 슬라이더 행 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingBottom="4dp">

            <!-- 펜촉 크기 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pen_size"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginEnd="10dp"/>

            <SeekBar
                android:id="@+id/seek_stroke_size"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="30"
                android:min="1"
                android:progress="4"
                android:progressTint="@color/colorPrimary"
                android:thumbTint="@color/colorPrimary"/>

            <TextView
                android:id="@+id/tv_stroke_size_value"
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:text="4"
                android:textColor="@color/colorTextPrimary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginHorizontal="4dp"/>

            <!-- 펜 크기 미리보기 원 -->
            <View
                android:id="@+id/view_pen_preview"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@android:color/black"/>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
