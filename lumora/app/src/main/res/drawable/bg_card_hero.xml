<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 외곽 글로우 그림자 -->
    <item android:left="2dp" android:right="2dp" android:top="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="@color/lumora_card_top"
                android:endColor="@color/lumora_card" />
            <corners android:radius="22dp" />
            <stroke android:width="1dp" android:color="#335BE3C3" />
        </shape>
    </item>
    <!-- 좌측 강조 라인 -->
    <item android:left="2dp" android:right="0dp" android:top="2dp" android:bottom="2dp" android:gravity="left">
        <shape android:shape="rectangle">
            <size android:width="4dp" />
            <solid android:color="@color/lumora_accent" />
            <corners android:topLeftRadius="22dp" android:bottomLeftRadius="22dp" />
        </shape>
    </item>
</layer-list>
