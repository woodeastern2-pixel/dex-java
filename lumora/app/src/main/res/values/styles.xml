<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Lumora" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/lumora_accent</item>
        <item name="colorPrimaryDark">@color/lumora_bg_bottom</item>
        <item name="colorAccent">@color/lumora_accent</item>
        <item name="android:windowBackground">@color/lumora_bg_top</item>
        <item name="android:statusBarColor">@color/lumora_bg_top</item>
        <item name="android:textColor">@color/lumora_text_primary</item>
    </style>

    <style name="Lumora" />

    <style name="Lumora.SectionTitle">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/lumora_text_primary</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Lumora.Title">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/lumora_text_primary</item>
    </style>

    <style name="Lumora.Body">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/lumora_text_secondary</item>
        <item name="android:lineSpacingExtra">3dp</item>
    </style>

    <style name="Lumora.Card">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:padding">18dp</item>
    </style>

    <style name="Lumora.PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/lumora_accent</item>
        <item name="android:textColor">#0F2A3A</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Lumora.GhostButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/lumora_accent</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/lumora_text_primary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:focusable">true</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Lumora.Chip">
        <item name="android:background">@drawable/bg_chip</item>
        <item name="android:textColor">@color/lumora_text_primary</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Brand wordmark (LUMORA) -->
    <style name="Lumora.Wordmark">
        <item name="android:textSize">40sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/lumora_text_primary</item>
        <item name="android:letterSpacing">0.22</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:shadowColor">#805BE3C3</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">14</item>
    </style>

    <style name="Lumora.WordmarkSub">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/lumora_accent</item>
        <item name="android:letterSpacing">0.18</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Hero / glass card variants -->
    <style name="Lumora.HeroCard">
        <item name="android:background">@drawable/bg_card_hero_attach</item>
        <item name="android:padding">20dp</item>
        <item name="android:elevation">6dp</item>
    </style>

    <style name="Lumora.GlassCard">
        <item name="android:background">@drawable/bg_card_glass</item>
        <item name="android:padding">16dp</item>
    </style>

    <!-- AX: large primary touch button (min 56dp height) -->
    <style name="Lumora.PrimaryButton.Large" parent="Lumora.PrimaryButton">
        <item name="android:minHeight">56dp</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- AX: large ghost button with improved touch target and contrast -->
    <style name="Lumora.GhostButton.Large" parent="Lumora.GhostButton">
        <item name="android:minHeight">56dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Lumora.DrawerItemText" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">21sp</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>
