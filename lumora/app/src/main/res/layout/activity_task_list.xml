<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_lumora_gradient">

    <TextView
        style="@style/Lumora.SectionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/task_title" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="14dp">

        <Button android:id="@+id/fToday" style="@style/Lumora.GhostButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginEnd="6dp" android:text="@string/task_filter_today" />
        <Button android:id="@+id/fUpcoming" style="@style/Lumora.GhostButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginEnd="6dp" android:text="@string/task_filter_upcoming" />
        <Button android:id="@+id/fDone" style="@style/Lumora.GhostButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginEnd="6dp" android:text="@string/task_filter_done" />
        <Button android:id="@+id/fAll" style="@style/Lumora.GhostButton"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/task_filter_all" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="14dp" />

    <TextView
        android:id="@+id/emptyMessage"
        style="@style/Lumora.Body"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:text="@string/task_list_empty"
        android:visibility="gone" />
</LinearLayout>
