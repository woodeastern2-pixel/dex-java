<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainDrawer"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@drawable/bg_lumora_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ===== Brand header ===== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="44dp">

            <LinearLayout
                android:id="@+id/brandHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:focusable="true"
                android:contentDescription="@string/cd_app_logo">

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_lumora_emblem"
                    android:importantForAccessibility="no"
                    android:layout_marginBottom="8dp" />

                <TextView
                    style="@style/Lumora.Wordmark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_wordmark" />

                <View
                    android:layout_width="44dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="6dp"
                    android:background="@color/lumora_accent" />

                <TextView
                    style="@style/Lumora.WordmarkSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="@string/app_acronym" />

                <TextView
                    style="@style/Lumora.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:alpha="0.85"
                    android:text="@string/app_tagline" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/openDrawerButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="top|end"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip"
                android:contentDescription="@string/main_open_menu"
                android:padding="10dp"
                android:src="@drawable/ic_hamburger_equal"
                android:tint="@color/lumora_text_primary" />
        </FrameLayout>

        <!-- ===== Briefing hero card ===== -->
        <LinearLayout
            style="@style/Lumora.HeroCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    style="@style/Lumora.SectionTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/main_briefing_title" />

                <TextView
                    style="@style/Lumora.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="L.U.M.O.R.A." />
            </LinearLayout>

            <TextView
                android:id="@+id/briefingText"
                style="@style/Lumora.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:lineSpacingExtra="4dp"
                android:singleLine="true"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:scrollHorizontally="true"
                tools:text="좋은 아침이에요. 오늘 할 일 3건이 있어요." />
        </LinearLayout>

        <!-- ===== Quick add ===== -->
        <TextView
            android:id="@+id/quickHintTicker"
            style="@style/Lumora.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:scrollHorizontally="true"
            android:text="@string/main_quick_add_hint" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <EditText
                android:id="@+id/quickInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chip"
                android:hint="@string/main_quick_input_hint"
                android:contentDescription="@string/cd_quick_add"
                android:textColorHint="@color/lumora_text_secondary"
                android:textColor="@color/lumora_text_primary"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:maxLines="1"
                android:freezesText="true"
                android:padding="14dp" />

            <ImageButton
                android:id="@+id/quickMic"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_chip"
                android:src="@drawable/ic_mic"
                android:tint="@color/lumora_accent"
                android:scaleType="centerInside"
                android:contentDescription="@string/cd_voice_input" />

            <Button
                android:id="@+id/quickAdd"
                style="@style/Lumora.PrimaryButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="52dp"
                android:layout_marginStart="6dp"
                android:contentDescription="@string/cd_quick_add_button"
                android:text="@string/main_quick_add" />
        </LinearLayout>

        <!-- ===== Today section ===== -->
        <TextView
            style="@style/Lumora.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/main_section_today" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/todayList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:id="@+id/todayEmpty"
            style="@style/Lumora.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/main_empty_today"
            android:visibility="gone" />

        <!-- ===== Habits section ===== -->
        <TextView
            style="@style/Lumora.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/main_section_habits" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/habitList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:id="@+id/habitEmpty"
            style="@style/Lumora.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/main_empty_habits"
            android:visibility="gone" />

        <!-- ===== Drawer navigation hint ===== -->
        <TextView
            style="@style/Lumora.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/main_nav_hint" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="@color/lumora_divider" />

        <TextView
            style="@style/Lumora.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/main_legal_section" />

        <Button
            android:id="@+id/openLegal"
            style="@style/Lumora.GhostButton.Large"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/main_open_legal" />

        <TextView
            style="@style/Lumora.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/main_legal_desc" />

        <TextView
            android:id="@+id/versionLabel"
            style="@style/Lumora.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            tools:text="버전 1.0" />
    </LinearLayout>
    </ScrollView>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/mainNavView"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@drawable/bg_drawer_panel"
        app:headerLayout="@layout/nav_header_main"
        app:itemTextAppearance="@style/Lumora.DrawerItemText"
        app:itemBackground="@android:color/transparent"
        app:itemIconTint="@color/lumora_accent"
        app:itemTextColor="@color/lumora_text_primary"
        app:menu="@menu/menu_main_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
