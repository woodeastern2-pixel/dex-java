<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginTop="6dp">

    <View
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="@color/lumora_accent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="14dp"
        android:background="@drawable/bg_card_attach">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/habitName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/lumora_text_primary"
                android:textSize="15sp"
                android:singleLine="false"
                android:maxLines="2"
                tools:text="아침 약 먹기" />

            <TextView
                android:id="@+id/habitMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/lumora_text_secondary"
                android:textSize="12sp"
                tools:text="08:00 · 5일 연속" />
        </LinearLayout>

        <Button
            android:id="@+id/btnCheck"
            style="@style/Lumora.PrimaryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="@string/habit_check_today" />

        <Button
            android:id="@+id/btnEdit"
            style="@style/Lumora.GhostButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/common_edit" />

        <Button
            android:id="@+id/btnDelete"
            style="@style/Lumora.GhostButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/common_delete" />
    </LinearLayout>
</LinearLayout>
