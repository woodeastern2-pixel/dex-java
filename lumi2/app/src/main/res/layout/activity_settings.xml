<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_lumi_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="32dp">

        <TextView
            style="@style/Lumi.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title" />

        <TextView
            style="@style/Lumi.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/settings_intro" />

        <LinearLayout
            style="@style/Lumi.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical">

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_avatar_section_title" />

            <TextView
                style="@style/Lumi.Muted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/settings_avatar_section_desc" />

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/settings_avatar_style" />

            <Spinner
                android:id="@+id/avatarStyleSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp" />

            <ImageView
                android:id="@+id/avatarPreview"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:adjustViewBounds="true"
                android:background="@drawable/bg_lumi_orb"
                android:contentDescription="@string/chat_lumi_image_desc"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_lumi_avatar_feminine" />

            <Button
                android:id="@+id/chooseAvatarButton"
                style="@style/Lumi.GhostButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/settings_avatar_pick_album" />

            <Button
                android:id="@+id/clearAvatarButton"
                style="@style/Lumi.GhostButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_avatar_clear_album" />
        </LinearLayout>

        <LinearLayout
            style="@style/Lumi.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical">

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:text="@string/settings_llm_section_title" />

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:text="@string/settings_provider" />

            <Spinner
                android:id="@+id/providerSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:visibility="gone" />

            <CheckBox
                android:id="@+id/useRemoteCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:visibility="gone"
                android:text="@string/settings_use_remote"
                android:textColor="?android:attr/textColorPrimary" />

            <CheckBox
                android:id="@+id/proactiveCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:visibility="gone"
                android:text="@string/settings_proactive"
                android:textColor="?android:attr/textColorPrimary" />

            <TextView
                style="@style/Lumi.Muted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:visibility="gone"
                android:text="@string/settings_proactive_desc" />

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/settings_proactive_plan_title" />

            <TextView
                style="@style/Lumi.Muted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/settings_proactive_daily_min" />

            <Spinner
                android:id="@+id/proactiveDailyMinSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp" />

            <TextView
                style="@style/Lumi.Muted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/settings_proactive_interval_min" />

            <Spinner
                android:id="@+id/proactiveIntervalMinSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp" />

            <TextView
                style="@style/Lumi.Muted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/settings_proactive_interval_max" />

            <Spinner
                android:id="@+id/proactiveIntervalMaxSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp" />

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/settings_tts_speed_title" />

            <TextView
                style="@style/Lumi.Muted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/settings_tts_speed_desc" />

            <Spinner
                android:id="@+id/ttsSpeedSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp" />

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/settings_tts_voice_title" />

            <TextView
                style="@style/Lumi.Muted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/settings_tts_voice_desc" />

            <Spinner
                android:id="@+id/ttsVoiceSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp" />

            <Button
                android:id="@+id/ttsPreviewButton"
                style="@style/Lumi.GhostButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_tts_preview" />

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:visibility="gone"
                android:text="@string/settings_api_key" />

            <EditText
                android:id="@+id/apiKeyField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:visibility="gone"
                android:hint="sk-..."
                android:inputType="textVisiblePassword"
                android:autofillHints="password"
                tools:ignore="HardcodedText" />

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:visibility="gone"
                android:text="@string/settings_model" />

            <EditText
                android:id="@+id/modelField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:visibility="gone"
                android:hint="@string/settings_hint_openai"
                android:inputType="text" />

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:visibility="gone"
                android:text="@string/settings_base_url" />

            <EditText
                android:id="@+id/baseUrlField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:visibility="gone"
                android:hint="https://..."
                android:inputType="textUri"
                tools:ignore="HardcodedText" />

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/settings_user_name" />

            <EditText
                android:id="@+id/userNameField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:inputType="textPersonName" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/imageSettingsSection"
            style="@style/Lumi.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:visibility="gone"
            android:orientation="vertical">

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_image_section_title" />

            <TextView
                style="@style/Lumi.Muted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/settings_image_section_desc" />

            <CheckBox
                android:id="@+id/imageGenEnableCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/settings_image_enable"
                android:textColor="?android:attr/textColorPrimary" />

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/settings_image_provider" />

            <Spinner
                android:id="@+id/imageProviderSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp" />

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/settings_image_api_key" />

            <EditText
                android:id="@+id/imageApiKeyField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="@string/settings_image_api_key_hint_openai"
                android:inputType="textVisiblePassword"
                android:autofillHints="password"
                tools:ignore="TextFields" />

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/settings_image_model" />

            <EditText
                android:id="@+id/imageModelField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="@string/settings_image_hint_openai"
                android:inputType="text" />

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/settings_image_base_url" />

            <EditText
                android:id="@+id/imageBaseUrlField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:hint="https://..."
                android:inputType="textUri"
                tools:ignore="HardcodedText" />

            <CheckBox
                android:id="@+id/nsfwCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/settings_nsfw"
                android:textColor="?android:attr/textColorPrimary" />

            <TextView
                style="@style/Lumi.Muted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/settings_nsfw_desc" />

            <TextView
                style="@style/Lumi.Muted"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/settings_image_save_guide" />
        </LinearLayout>


        <Button
            android:id="@+id/saveButton"
            style="@style/Lumi.PrimaryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/settings_save" />

        <Button
            android:id="@+id/testButton"
            style="@style/Lumi.GhostButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/settings_test" />

        <Button
            android:id="@+id/imageTestButton"
            style="@style/Lumi.GhostButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            android:text="@string/settings_image_test" />

        <LinearLayout
            style="@style/Lumi.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="vertical">

            <TextView
                style="@style/Lumi.SectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_reset_section" />

            <Button
                android:id="@+id/resetChatButton"
                style="@style/Lumi.GhostButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/settings_reset_chat" />

            <Button
                android:id="@+id/resetMemoryButton"
                style="@style/Lumi.GhostButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_reset_memory" />

            <Button
                android:id="@+id/resetAllButton"
                style="@style/Lumi.GhostButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_reset_all" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
